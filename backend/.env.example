ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:your_password@127.0.0.1:5432/eduquiz
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_COOKIE_NAME=eduquiz_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
SESSION_TTL_HOURS=24
REMEMBER_SESSION_TTL_DAYS=30
TERMS_VERSION=2026-06-24
PUBLIC_APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_CHECKOUT_SUCCESS_PATH=/upgrade?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_PATH=/upgrade?checkout=cancelled
PROJECT_STORAGE_DIR=storage/projects
PROJECT_UPLOAD_MAX_MB=100
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_ECHO=false
